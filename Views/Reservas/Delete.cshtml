@model TechRent.Models.Reserva

@{
    ViewData["Title"] = "Eliminar Reserva";
}

<div class="container mt-4">
    <h1><i class="bi bi-trash text-danger"></i> Eliminar Reserva</h1>
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i> ¿Estás seguro de eliminar esta reserva?
    </div>
    <div class="card">
        <div class="card-body">
            <p><strong>Cliente:</strong> @Model.Cliente?.NombreCompleto</p>
            <p><strong>Estado:</strong> @Model.EstadoReserva?.Nombre</p>
            <p><strong>Fecha Inicio:</strong> @Model.FechaInicio.ToString("dd/MM/yyyy")</p>
            <p><strong>Fecha Fin:</strong> @Model.FechaFin.ToString("dd/MM/yyyy")</p>
            <p><strong>Monto Total:</strong> $@Model.MontoTotal.ToString("0.00")</p>
        </div>
    </div>
    <form asp-action="Delete" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
    </form>
</div>
