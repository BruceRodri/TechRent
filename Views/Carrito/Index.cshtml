@model IEnumerable<TechRent.Models.CarritoItem>

@{
    ViewData["Title"] = "Mi Carrito";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1><i class="bi bi-cart3" style="color: #4361ee;"></i> Mi Carrito</h1>
            <p class="text-muted">Equipos seleccionados para alquiler</p>
        </div>
        <a asp-controller="Equipos" asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Seguir agregando
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-cart-x" style="font-size: 4rem; color: #ccc;"></i>
                <h3 class="mt-3 text-muted">Tu carrito está vacío</h3>
                <p class="text-muted">Explora nuestro catálogo y agrega equipos para alquilar.</p>
                <a asp-controller="Equipos" asp-action="Index" class="btn btn-primary btn-lg mt-2">
                    <i class="bi bi-laptop"></i> Ver Equipos
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th><i class="bi bi-laptop"></i> Equipo</th>
                            <th><i class="bi bi-tag"></i> Categoría</th>
                            <th><i class="bi bi-currency-dollar"></i> Precio/Día</th>
                            <th><i class="bi bi-hash"></i> Cantidad</th>
                            <th><i class="bi bi-calendar"></i> Días</th>
                            <th><i class="bi bi-calculator"></i> Subtotal</th>
                            <th><i class="bi bi-gear"></i> Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.Equipo.Nombre</strong>
                                    <br />
                                    <small class="text-muted">@item.Equipo.Marca?.Nombre</small>
                                </td>
                                <td><span class="badge bg-info">@item.Equipo.Categoria?.Nombre</span></td>
                                <td>$@item.Equipo.PrecioPorDia.ToString("0.00")</td>
                                <td>
                                    <form asp-action="Actualizar" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="dias" value="@item.Dias" />
                                        <div class="input-group input-group-sm" style="width: 100px;">
                                            <input type="number" name="cantidad" value="@item.Cantidad" min="1" max="@item.Equipo.Stock" class="form-control" />
                                            <button type="submit" class="btn btn-outline-primary btn-sm"><i class="bi bi-arrow-repeat"></i></button>
                                        </div>
                                    </form>
                                </td>
                                <td>
                                    <form asp-action="Actualizar" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="cantidad" value="@item.Cantidad" />
                                        <div class="input-group input-group-sm" style="width: 100px;">
                                            <input type="number" name="dias" value="@item.Dias" min="1" max="365" class="form-control" />
                                            <button type="submit" class="btn btn-outline-primary btn-sm"><i class="bi bi-arrow-repeat"></i></button>
                                        </div>
                                    </form>
                                </td>
                                <td>
                                    <strong class="text-success">$@((item.Cantidad * item.Equipo.PrecioPorDia * item.Dias).ToString("0.00"))</strong>
                                </td>
                                <td>
                                    <form asp-action="Eliminar" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-md-6">
                <form asp-action="Vaciar" method="post">
                    <button type="submit" class="btn btn-outline-danger btn-lg">
                        <i class="bi bi-trash3"></i> Vaciar Carrito
                    </button>
                </form>
            </div>
            <div class="col-md-6 text-end">
                <div class="card bg-light">
                    <div class="card-body">
                        <h4 class="mb-3">Total: <strong class="text-success">$@ViewBag.Total.ToString("0.00")</strong></h4>
                        <form asp-controller="Carrito" asp-action="ConfirmarReserva" method="post" class="mb-2">
                            <input type="hidden" name="metodoPago" value="PayPal" />
                            <button type="submit" class="btn btn-primary btn-lg w-100">
                                <i class="bi bi-paypal"></i> Pagar con PayPal
                            </button>
                        </form>
                        <form asp-controller="Carrito" asp-action="ConfirmarReserva" method="post">
                            <input type="hidden" name="metodoPago" value="PayPhone" />
                            <button type="submit" class="btn btn-success btn-lg w-100">
                                <i class="bi bi-phone"></i> Pagar con PayPhone
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
