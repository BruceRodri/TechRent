@model TechRent.Models.Equipo

@{
    ViewData["Title"] = "Nuevo Equipo";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0">
                        <i class="bi bi-plus-circle"></i> Registrar Nuevo Equipo
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="All" class="alert alert-danger"></div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nombre" class="form-label fw-bold">
                                    <i class="bi bi-laptop"></i> Nombre del Equipo
                                </label>
                                <input asp-for="Nombre" class="form-control" placeholder="Ej: Laptop HP Pavilion" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="Stock" class="form-label fw-bold">
                                    <i class="bi bi-box"></i> Cantidad en Stock
                                </label>
                                <input asp-for="Stock" class="form-control" type="number" min="0" />
                                <span asp-validation-for="Stock" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label fw-bold">
                                <i class="bi bi-file-text"></i> Descripción
                            </label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3" 
                                placeholder="Especificaciones técnicas del equipo..."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="PrecioPorDia" class="form-label fw-bold">
                                    <i class="bi bi-currency-dollar"></i> Precio por Día
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="PrecioPorDia" class="form-control" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="PrecioPorDia" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-4 mb-3">
                                <label asp-for="CategoriaId" class="form-label fw-bold">
                                    <i class="bi bi-tag"></i> Categoría
                                </label>
                                <select asp-for="CategoriaId" asp-items="ViewBag.CategoriaId" class="form-control" data-val="false">
                                    <option value="">Seleccione una categoría...</option>
                                </select>
                                <span asp-validation-for="CategoriaId" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-4 mb-3">
                                <label asp-for="MarcaId" class="form-label fw-bold">
                                    <i class="bi bi-building"></i> Marca
                                </label>
                                <select asp-for="MarcaId" asp-items="ViewBag.MarcaId" class="form-control">
                                    <option value="">Seleccione una marca...</option>
                                </select>
                                <span asp-validation-for="MarcaId" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Especificaciones" class="form-label fw-bold">
                                <i class="bi bi-motherboard"></i> Especificaciones Técnicas
                            </label>
                            <textarea asp-for="Especificaciones" class="form-control" rows="2" 
                                placeholder="Procesador, RAM, almacenamiento, etc."></textarea>
                        </div>
                        
                        <hr />
                        
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Guardar Equipo
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}