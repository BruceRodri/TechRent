@model TechRent.Models.Categoria

@{
    ViewData["Title"] = "Detalle de Categoría";
}

<div class="container mt-4">
    <h1><i class="bi bi-eye"></i> Detalle de Categoría</h1>
    <hr />
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.Nombre</h5>
            <p class="card-text">@(Model.Descripcion ?? "Sin descripción")</p>
            <ul class="list-group list-group-flush">
                <li class="list-group-item"><strong>ID:</strong> @Model.Id</li>
                <li class="list-group-item"><strong>Fecha Creación:</strong> @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</li>
            </ul>
        </div>
    </div>
    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> Editar</a>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
    </div>
</div>
