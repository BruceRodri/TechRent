@model TechRent.Models.TransaccionPago

@{
    ViewData["Title"] = "Detalle del Pago";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg">
                <div class="card-header text-center py-3 @(Model.Estado == "Pagado" ? "bg-success" : Model.Estado == "Cancelado" ? "bg-danger" : "bg-warning") text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-receipt"></i> Detalle del Pago
                    </h4>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-6">
                            <strong>Orden:</strong> #@Model.OrdenAlquilerId
                        </div>
                        <div class="col-6">
                            <strong>Pasarela:</strong> @Model.Proveedor
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <strong>Estado:</strong>
                            @if (Model.Estado == "Pagado")
                            {
                                <span class="badge bg-success">@Model.Estado</span>
                            }
                            else if (Model.Estado == "Cancelado")
                            {
                                <span class="badge bg-danger">@Model.Estado</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@Model.Estado</span>
                            }
                        </div>
                        <div class="col-6">
                            <strong>Total:</strong>
                            <span class="text-success fs-5">$@((Model.MontoEnCentavos / 100m).ToString("0.00"))</span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-12">
                            <strong>Transacción cliente:</strong> @Model.ClientTransactionId
                        </div>
                    </div>

                    @if (Model.OrdenAlquiler?.Detalles != null && Model.OrdenAlquiler.Detalles.Any())
                    {
                        <hr />
                        <h5>Detalle de la orden</h5>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Equipo</th>
                                    <th>Cant.</th>
                                    <th>Días</th>
                                    <th>Precio/Día</th>
                                    <th>Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in Model.OrdenAlquiler.Detalles)
                                {
                                    <tr>
                                        <td>@d.NombreEquipo</td>
                                        <td>@d.Cantidad</td>
                                        <td>@d.Dias</td>
                                        <td>$@d.PrecioPorDia.ToString("0.00")</td>
                                        <td>$@d.Subtotal.ToString("0.00")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    @if (Model.Proveedor == "PayPhone" && Model.Estado == "Pendiente" && !string.IsNullOrWhiteSpace(Model.PayphonePaymentUrl))
                    {
                        <a class="btn btn-success btn-lg w-100 mt-3" href="@Model.PayphonePaymentUrl" target="_blank">
                            <i class="bi bi-credit-card"></i> Abrir link de pago PayPhone
                        </a>
                    }

                    @if (Model.Estado == "Pagado")
                    {
                        <div class="alert alert-success mt-3 mb-0">
                            <i class="bi bi-check-circle"></i> Pago confirmado correctamente.
                        </div>
                    }

                    @if (User.IsInRole("Administrador") && Model.Estado == "Pendiente")
                    {
                        <a class="btn btn-warning w-100 mt-3" asp-action="MarcarPagado" asp-route-id="@Model.Id">
                            <i class="bi bi-check2-circle"></i> Marcar como pagado (demo)
                        </a>
                    }
                </div>
            </div>

            <div class="mt-3">
                <a asp-controller="Carrito" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Volver al carrito
                </a>
            </div>
        </div>
    </div>
</div>
