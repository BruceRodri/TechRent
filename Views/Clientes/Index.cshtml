@model IEnumerable<TechRent.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>
                <i class="bi bi-people-fill" style="color: #4361ee;"></i> 
                Nuestros Clientes
            </h1>
            <p class="text-muted">Gestión de clientes que alquilan equipos tecnológicos</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="bi bi-person-plus-fill"></i> Nuevo Cliente
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="dashboard-card">
                <i class="bi bi-people-fill" style="color: #4361ee;"></i>
                <div class="number">@ViewBag.TotalRegistros</div>
                <div class="text-muted">Clientes Registrados</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="dashboard-card">
                <i class="bi bi-envelope-fill" style="color: #06d6a0;"></i>
                <div class="number">@ViewBag.ClientesConEmail</div>
                <div class="text-muted">Correos Registrados</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="dashboard-card">
                <i class="bi bi-telephone-fill" style="color: #f72585;"></i>
                <div class="number">@ViewBag.ClientesConTelefono</div>
                <div class="text-muted">Teléfonos Registrados</div>
            </div>
        </div>
    </div>

    <form method="get" class="mb-3">
        <div class="input-group">
            <input type="text" name="searchString" class="form-control" placeholder="Buscar por nombre, email o teléfono..." value="@ViewBag.SearchString" />
            <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Buscar</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-circle"></i> Limpiar</a>
        </div>
    </form>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h5 class="card-title">
                                    <i class="bi bi-person-circle" style="color: #4361ee;"></i>
                                    @item.NombreCompleto
                                </h5>
                                <h6 class="card-subtitle mb-2 text-muted">
                                    <i class="bi bi-person-badge"></i> ID: @item.DocumentoIdentidad
                                </h6>
                            </div>
                            <span class="badge bg-success rounded-pill">Activo</span>
                        </div>
                        
                        <hr />
                        
                        <div class="mb-2">
                            <i class="bi bi-envelope-fill text-primary"></i>
                            <small>@item.Email</small>
                        </div>
                        <div class="mb-2">
                            <i class="bi bi-telephone-fill text-success"></i>
                            <small>@item.Telefono</small>
                        </div>
                        <div class="mb-3">
                            <i class="bi bi-geo-alt-fill text-danger"></i>
                            <small>@(item.Direccion ?? "Sin dirección registrada")</small>
                        </div>
                        
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                                <i class="bi bi-eye"></i> Ver
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>
                    <div class="card-footer text-muted">
                        <small>
                            <i class="bi bi-calendar"></i> Registrado: @item.FechaCreacion.ToString("dd/MM/yyyy")
                        </small>
                    </div>
                </div>
            </div>
        }
    </div>

    @await Html.PartialAsync("_Pagination")
</div>
